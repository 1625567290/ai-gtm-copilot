# Supabase Postgres connection string.
# Recommended for this demo: Supabase Dashboard -> Project Settings -> Database -> Connection string -> Session pooler.
# URL-encode special characters in the password.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional AI mode. The app is fully usable without these values.
# AI_GENERATION_MODE="openai"
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
